# =======================================
# BookBot — Configuration
# =======================================

# Environnement : development | production
NODE_ENV=development

# --- Tokens Discord ---
DEV_TOKEN=TON_TOKEN_DEV_ICI
PROD_TOKEN=TON_TOKEN_PROD_ICI

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=bookbot
DB_PASSWORD=CHANGE_MOI
DB_NAME=bookbot

# --- Google Books API ---
# Clé API disponible sur : https://console.cloud.google.com/
GOOGLE_BOOKS_API_KEY=TA_CLE_GOOGLE_BOOKS_ICI

# --- Overlay OBS ---
# Port du serveur HTTP interne (peu commun)
OVERLAY_PORT=8437
# Domaine public pour l'URL OBS
OVERLAY_BASE_URL=https://sanchez-florian.fr

# --- Musique (Flux Radio Creative Commons) ---
# URL du flux radio par défaut
RADIO_CHILLHOP_URL=https://streams.ilovemusic.de/iloveradio17.mp3
RADIO_LOFI_URL=http://stream.zeno.fm/f3wvbbqmdg8uv
RADIO_JAZZ_URL=http://stream.zeno.fm/wrv5ykqm7grudv

# --- Signaux sonores de session ---
# Fichiers audio pour début/fin de sprint
AUDIO_SESSION_START=./audio/session_start.mp3
AUDIO_SESSION_END=./audio/session_end.mp3
